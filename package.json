{
  "name": "fetcher",
  "version": "10.0.0",
  "description": "a media downloader",
  "engines": {
    "node": ">=24.11.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "type": "module",
  "scripts": {
    "start-dev": "run-p -lr start-dev:*",
    "start-dev:frontend": "webpack --watch --progress",
    "start-dev:server": "tsx src/index.ts",
    "build": "pnpm clean && run-p --aggregate-output build:*",
    "build:ts": "tsc --outDir dist/",
    "build:pug": "mkdir -p dist/views && cp -fr src/views dist",
    "build:frontend": "webpack --color",
    "lint": "run-p --aggregate-output --continue-on-error lint:*",
    "lint:eslint": "eslint src/**/*.{ts,js} *.config.cjs",
    "lint:prettier": "prettier --check 'src/**/*.{ts,js}'",
    "lint:stylelint": "stylelint --color 'src/**/*.css'",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "test": "NODE_ENV=test LOG_LEVEL=silent c8 mocha --require tsx --color 'src/**/*.spec.ts' --exit",
    "clean": "rm -rf .nyc_output/ dist/"
  },
  "dependencies": {
    "chalk": "5.6.0",
    "express": "4.22.2",
    "form-data": "4.0.6",
    "got": "14.6.6",
    "irc-colors": "1.5.0",
    "irc-framework": "4.14.0",
    "level": "8.0.1",
    "loglevel": "1.9.2",
    "loglevel-plugin-prefix": "0.8.4",
    "pug": "3.0.4",
    "rss-parser": "3.13.0",
    "source-map-support": "0.5.21",
    "tough-cookie": "6.0.1",
    "tslib": "2.8.1",
    "webtorrent": "2.8.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/chai": "5.2.3",
    "@types/express": "4.17.25",
    "@types/mocha": "10.0.10",
    "@types/node": "24.13.2",
    "@types/sinon": "22.0.0",
    "@types/stream-buffers": "3.0.8",
    "@types/xml2js": "0.4.14",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "c8": "11.0.0",
    "chai": "6.2.2",
    "css-loader": "7.1.4",
    "cssnano": "8.0.2",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "jquery": "4.0.0",
    "mini-css-extract-plugin": "2.10.2",
    "mocha": "11.7.6",
    "mock-fs": "5.5.0",
    "npm-run-all2": "9.0.2",
    "postcss": "8.5.16",
    "postcss-loader": "8.2.1",
    "prettier": "3.9.4",
    "sinon": "22.0.0",
    "stream-buffers": "3.0.3",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3",
    "webpack-manifest-plugin": "5.0.1"
  }
}
